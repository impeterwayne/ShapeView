# ── Example secrets file ─────────────────────────────────────────────────────
# Copy this file to `local.secret.properties` and fill in your values.
# The actual local.secret.properties file is git-ignored.

# GPG Signing (Maven Central)
signing.keyId=YOUR_KEY_ID
signing.password=YOUR_GPG_PASSWORD
signing.secretKeyRingFile=/path/to/your/secring.gpg

# Sonatype / Maven Central credentials
mavenCentralUsername=YOUR_SONATYPE_USERNAME
mavenCentralPassword=YOUR_SONATYPE_PASSWORD
